# Agent Broker — environment configuration
# Copy to .env and adjust for your deployment.
# See DESIGN.md §11 for the full architecture surface.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Single shared secret that authorizes the operator (web UI + REST mutations).
# Placeholder values starting with `GENERATE_WITH_` fail loud.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DELPHI_OPERATOR_TOKEN=GENERATE_WITH_token_hex_32

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
# DELPHI_HOST is the bind address for uvicorn INSIDE the container. Canonical
# deployment is via docker-compose (see comment on DELPHI_DB_PATH below), so
# 0.0.0.0 is required for Docker port forwarding to reach the broker. If you
# run the broker directly on the host (no container), set to 127.0.0.1.
DELPHI_HOST=0.0.0.0
DELPHI_PORT=8420
DELPHI_MCP_HOST_REGISTRY=127.0.0.1:*,localhost:*
DELPHI_MCP_ORIGIN_REGISTRY=http://127.0.0.1:8420,http://localhost:8420
# Explicit CIDR list allowed to omit Origin because ingress IP proves a
# private transport boundary. Empty means loopback-only.
DELPHI_ORIGINLESS_TRUSTED_INGRESS_CIDRS=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Relative paths are resolved from the repository root. In Docker, the
# repository root is `/app`, so this still resolves to `/app/data/delphi.db`.
DELPHI_DB_PATH=data/delphi.db

# ---------------------------------------------------------------------------
# Agent identity
# ---------------------------------------------------------------------------
# Public agent manifest (committed canonical seed; structural fields only,
# no inline secrets).
DELPHI_AGENTS_PATH=config/agents.json
# Default to the committed empty seed so a fresh clone can start. Deployments
# with local historical exclusions may point this at a gitignored local file.
OPERATOR_PERMANENTLY_HIDDEN_THREADS_PATH=config/operator_permanently_hidden_threads.json.example

# Registered participant identity bound to operator mark-read authority.
# The request body cannot override this value.
OPERATOR_PARTICIPANT_ID=operator

# Designated arbitrator and executor agent ids. The executor must be a
# separately-registered identity (role='executor' in agents.json) — it cannot
# share an agent_id with a worker. See DESIGN.md §2.
DELPHI_ARBITRATOR_AGENT_ID=flow-claude
DELPHI_EXECUTOR_AGENT_ID=dev-codex-executor

# ---------------------------------------------------------------------------
# Per-agent HMAC secrets (env-SSOT)
# ---------------------------------------------------------------------------
# Convention: DELPHI_AGENT_SECRET_<NORMALIZED_AGENT_ID> where normalization
# uppercases the agent_id and replaces `-` with `_`. Every agent registered
# in config/agents.json must have a matching env var here. Missing values
# fail loud at broker startup. Placeholder values starting with
# `GENERATE_WITH_` also fail loud (prevents copying .env.example unchanged).
# Generate each with:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Identity-naming patterns (see config/agents.json $schema):
# - `<base>` = primary identity (e.g., dev-codex)
# - `<base>-peer` = peer-direct sibling for terminal-approved-then-direct-peer
#   workflows (collaboration_governed=false; cf. prod-codex-peer)
# - `<base>-<role>` = role-specific separate identity (e.g.,
#   dev-codex-executor for the executor role distinct from dev-codex worker)
#
# Approval-authority + arbitration:
DELPHI_AGENT_SECRET_OPERATOR=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_FLOW_CLAUDE=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_DEV_CODEX_EXECUTOR=GENERATE_WITH_token_hex_32
#
# Lexx collab-pipeline workers + their peer-direct siblings:
DELPHI_AGENT_SECRET_DEV_CODEX=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_DEV_CODEX_PEER=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_DEV_CLAUDE=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_DEV_CLAUDE_PEER=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_PROD_CODEX=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_PROD_CODEX_PEER=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_PROD_CLAUDE=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_PROD_CLAUDE_PEER=GENERATE_WITH_token_hex_32
#
# Peer-direct primary identities (stocks-broker / cross-host coordination):
DELPHI_AGENT_SECRET_BSFLOW_CLAUDE=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_PI_CLAUDE=GENERATE_WITH_token_hex_32
DELPHI_AGENT_SECRET_PI_CODEX=GENERATE_WITH_token_hex_32

# ---------------------------------------------------------------------------
# Web UI
# ---------------------------------------------------------------------------
# Set to true (or 1/yes) when the broker is fronted by HTTPS so the operator
# session cookie is flagged Secure.
DELPHI_WEB_SECURE=false

# Enables the background process that advances expired Delphi v2 nudge windows.
# Set false only for isolated tests or a controlled operator pause.
DELPHI_NUDGE_SWEEP_ENABLED=true

# Enables FastMCP's Streamable HTTP session manager for the /mcp transport.
# Set false only when tests directly call tool functions without HTTP transport.
DELPHI_MCP_SESSION_MANAGER_ENABLED=true

# ---------------------------------------------------------------------------
# Tailscale exposure (optional — for cross-host agent peer_send)
# ---------------------------------------------------------------------------
# Set to this host's Tailscale IP only when using
# `docker compose -f docker-compose.yml -f docker-compose.tailscale.yml`.
# Also append the IP to DELPHI_MCP_HOST_REGISTRY and DELPHI_MCP_ORIGIN_REGISTRY
# above (e.g.
#   DELPHI_MCP_HOST_REGISTRY=127.0.0.1:*,localhost:*,100.x.y.z:*
#   DELPHI_MCP_ORIGIN_REGISTRY=...,http://100.x.y.z:8420
# ).
# BROKER_TAILSCALE_IP=
