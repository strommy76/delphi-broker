# Agent Broker — environment configuration
# Copy to .env and adjust for your deployment.
# See DESIGN.md §11 for the full architecture surface.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Single shared secret that authorizes the operator (web UI + REST mutations).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DELPHI_OPERATOR_TOKEN=change-me-to-a-random-string

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
DELPHI_HOST=127.0.0.1
DELPHI_PORT=8420
DELPHI_MCP_HOST_REGISTRY=127.0.0.1:*,localhost:*
DELPHI_MCP_ORIGIN_REGISTRY=http://127.0.0.1:8420,http://localhost:8420
# Explicit CIDR list allowed to omit Origin because ingress IP proves a
# private transport boundary. Empty means loopback-only.
DELPHI_ORIGINLESS_TRUSTED_INGRESS_CIDRS=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Relative paths are resolved from the project root.
# Docker override: /app/data/delphi.db (set in docker-compose.yml)
DELPHI_DB_PATH=delphi.db

# ---------------------------------------------------------------------------
# Agent identity
# ---------------------------------------------------------------------------
# Public agent manifest (committed); per-agent secrets sidecar (gitignored).
DELPHI_AGENTS_PATH=config/agents.json
DELPHI_AGENT_SECRETS_PATH=config/agents-secrets.json
OPERATOR_PERMANENTLY_HIDDEN_THREADS_PATH=config/operator_permanently_hidden_threads.json

# Registered participant identity bound to operator mark-read authority.
# The request body cannot override this value.
OPERATOR_PARTICIPANT_ID=operator

# Designated arbitrator and executor agent ids. The executor must be a
# separately-registered identity (role='executor' in agents.json) — it cannot
# share an agent_id with a worker. See DESIGN.md §2.
DELPHI_ARBITRATOR_AGENT_ID=flow-claude
DELPHI_EXECUTOR_AGENT_ID=dev-codex-executor

# ---------------------------------------------------------------------------
# Web UI
# ---------------------------------------------------------------------------
# Set to true (or 1/yes) when the broker is fronted by HTTPS so the operator
# session cookie is flagged Secure.
DELPHI_WEB_SECURE=false

# Enables the background process that advances expired Delphi v2 nudge windows.
# Set false only for isolated tests or a controlled operator pause.
DELPHI_NUDGE_SWEEP_ENABLED=true

# Enables FastMCP's Streamable HTTP session manager for the /mcp transport.
# Set false only when tests directly call tool functions without HTTP transport.
DELPHI_MCP_SESSION_MANAGER_ENABLED=true
